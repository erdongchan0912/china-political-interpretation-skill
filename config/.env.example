# China Political Interpretation - Environment Configuration
# =========================================================
# 请复制此文件为 .env 并填入您的 API Keys

# ===================
# LLM Configuration
# ===================

# LLM Provider: "gemini" (Google Gemini) 或 "openai" (OpenAI 兼容 API)
LLM_PROVIDER=gemini

# --- 方案1: Google Gemini API (推荐) ---
# 从 Google AI Studio 获取: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash

# --- 方案2: OpenAI 兼容 API ---
# 如需使用 OpenAI 格式的 API，请取消注释并配置以下选项：
# LLM_PROVIDER=openai
# LLM_API_KEY=your-openai-compatible-api-key-here
# LLM_API_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# ===================
# Server Configuration
# ===================

# Server host and port
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# ===================
# Debug Options
# ===================

# Enable debug logging
DEBUG=true

# Save intermediate results
SAVE_INTERMEDIATE=true

# ===================
# Search API Configuration
# ===================

# Tavily Search API (推荐 - 更稳定，专为 AI 应用设计)
# 免费注册获取 API Key: https://tavily.com/
# 免费额度: 每月 1000 次搜索
TAVILY_API_KEY=your-tavily-api-key-here

# Search API Provider (tavily / google)
SEARCH_API_PROVIDER=tavily

# --- 备选: Google Custom Search API ---
# 如需使用 Google 搜索，请配置以下选项：
# GOOGLE_SEARCH_API_KEY=your-google-search-api-key-here
# GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id-here
# SEARCH_API_PROVIDER=google

# ===================
# Output Archive (可选)
# ===================

# Permanent archive directory for analysis outputs (HTML/PDF/source markdown)
# Each analysis creates a subfolder: YYYY-MM-DD_<title>/
# ARCHIVE_DIR=~/Documents/政策分析输出
